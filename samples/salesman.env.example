# ============================================================
# /etc/salesman.env — copy this file to the openclaw VPS, fill
# in the placeholders, then `sudo systemctl restart salesman`.
#
# Suggested perms after copy:
#   sudo install -m 0640 -o root -g salesman \
#        salesman.env.example /etc/salesman.env
#
# Lines starting with # are comments. Quoted values let you
# include spaces and special characters. Run `salesman doctor`
# after editing to verify each block landed.
# ============================================================


# -----------------------------------------------------------
# 1. Database (postgres on openclaw — already set up)
# -----------------------------------------------------------
SALESMAN_DATABASE_URL=postgres://salesman:CHANGEME@/salesman?host=/var/run/postgresql


# -----------------------------------------------------------
# 2. LLM credentials — pick ONE of the two paths.
#
# PATH A — API keys (legacy, fastest):
#     Set ANTHROPIC_API_KEY and/or GEMINI_API_KEY below.
#     Each completion is billed at developer rates.
#
# PATH B — subscriber-login CLIs (uses your paid Pro/Max +
#     Gemini Advanced seats; flat-fee, no per-completion cost):
#     1. As the salesman user, run `claude login` and
#        `gemini auth login` once each (browser-auth flow).
#     2. Uncomment SALESMAN_LLM_TRANSPORT=cli below.
#     3. Leave the API keys empty (they're ignored when cli).
#     4. See docs/SUBSCRIBER_LOGIN.md for full instructions.
#     Note: Path B does NOT support tool-use (CLI returns plain
#     text). Tool-using call sites need Path A. Both can run
#     side-by-side if needed.
# -----------------------------------------------------------

# Path B (uncomment to engage):
# SALESMAN_LLM_TRANSPORT=cli

# Path A (or both):
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
BRAVE_SEARCH_API_KEY=                  # optional; enables OSINT search


# -----------------------------------------------------------
# 3. Sender identity (what the recipient sees in From:)
# -----------------------------------------------------------
SALESMAN_FROM_NAME="PlausiDen"
SALESMAN_FROM_EMAIL=salesman@outreach.plausiden.com
SALESMAN_REPLY_TO=william@plausiden.com
SALESMAN_COMPLIANCE_FOOTER="PlausiDen — sovereign data tools.\nReply STOP to opt out."


# -----------------------------------------------------------
# 4. SMTP submission (uses mail.plausiden.com on web-01)
#
# Note: salesman runs on openclaw but sends via web-01's
# Postfix on submission port 587. The actual sending IP that
# DNS records (SPF / PTR) authorize is web-01's
# 207.246.86.218, NOT openclaw's 45.77.217.37.
# STALE (pre-2026-05-31 rebuild): openclaw's 45.77.217.37 is dead
# (now 207.148.30.162); the sending topology above is UNVERIFIED
# post-rebuild — re-confirm the real sender on-box before any send
# (see HANDOFF.md). Not asserting a corrected sending IP here.
# -----------------------------------------------------------
SALESMAN_SMTP_HOST=mail.plausiden.com
SALESMAN_SMTP_PORT=587
SALESMAN_SMTP_USERNAME=salesman@plausiden.com
SALESMAN_SMTP_PASSWORD=CHANGEME


# -----------------------------------------------------------
# 5. RFC 8058 one-click unsubscribe (Gmail / Yahoo bulk-sender)
#
# Without these two vars the salesman-api /unsubscribe route is
# disabled and Gmail + Yahoo will progressively spam-bin the
# domain regardless of SPF/DKIM/DMARC. Generate the secret
# with: openssl rand -hex 32
# -----------------------------------------------------------
SALESMAN_UNSUBSCRIBE_BASE_URL=https://outreach.plausiden.com/unsubscribe
SALESMAN_UNSUBSCRIBE_HMAC_SECRET=CHANGEME_run_openssl_rand_hex_32


# -----------------------------------------------------------
# 6. IMAP — inbound reply ingestion
# -----------------------------------------------------------
SALESMAN_IMAP_HOST=mail.plausiden.com
SALESMAN_IMAP_PORT=993
SALESMAN_IMAP_USERNAME=salesman@plausiden.com
SALESMAN_IMAP_PASSWORD=CHANGEME
SALESMAN_IMAP_MAILBOX=INBOX


# -----------------------------------------------------------
# 7. Anti-spoof gate (Authentication-Results trust)
#
# Without this, classify-replies cannot defend against forged
# inbound replies that try to poison the suppression list. An
# attacker sending `From: alice@bigprospect.com` body "please
# remove me" would auto-suppress the real Alice. With it set,
# we honor the SPF/DKIM/DMARC verdict your MX already computes.
#
# Value is the hostname your mail server uses in the
# `Authentication-Results: <hostname>; ...` header it stamps
# on inbound. For the openclaw + web-01 setup that's
# `mail.plausiden.com`. Anything else is ignored.
# -----------------------------------------------------------
SALESMAN_TRUSTED_AUTHSERV_ID=mail.plausiden.com


# -----------------------------------------------------------
# 8. Operator brief (optional but recommended)
#
# 200-300 word brand voice / banned phrases / tone guide
# prepended to every system message. Keeps fallback LLMs
# tone-aligned per docs/MODEL_RESILIENCE.md.
# -----------------------------------------------------------
SALESMAN_OPERATOR_BRIEF=/opt/salesman/config/operator-brief.md


# -----------------------------------------------------------
# 9. Alerting (optional)
#
# Webhook URL hit by `salesman alerts` when there's actionable
# news (positive replies, opt-outs, bounces, legal threats,
# competitor mentions). Slack / Discord / generic JSON
# accepted; payload is JSON when --json, plain text otherwise.
# -----------------------------------------------------------
# SALESMAN_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/CHANGEME


# -----------------------------------------------------------
# 10. Cost ledger sink (optional)
#
# Set to skip recording LLM-call costs for tests / dry-runs.
# Default behavior records every call to the llm_calls table.
# -----------------------------------------------------------
# SALESMAN_LLM_NO_LEDGER=1
